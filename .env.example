# With no .env, the app uses PGlite at .ark/<PORT>/database and local uploads at .ark/<PORT>/uploads.
PORT=5400
BETTER_AUTH_SECRET=template-dev-secret-change-before-production
BETTER_AUTH_URL=http://localhost:5400
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5400,http://127.0.0.1:5400

ADMIN_USER=admin@example.com
ADMIN_PASSWORD=password
ADMIN_NAME=Template Admin

NUXT_PUBLIC_APP_NAME=Kurark Template
NUXT_PUBLIC_SITE_NAME=Kurark Template
NUXT_PUBLIC_SITE_URL=http://localhost:5400
NUXT_PUBLIC_INDEXABLE=false
NUXT_PUBLIC_YANDEX_METRIKA_ID=

ARK_DEFAULT_SLUG=template
# ARK_DEFAULT_NAME=Kurark Template

# Optional Telegram auth / bot integration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEB_APP_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_OAUTH_CLIENT_ID=
TELEGRAM_OAUTH_CLIENT_SECRET=

# Optional local Compose profile.
POSTGRES_PORT=5401
RUSTFS_PORT=5402
RUSTFS_CONSOLE_PORT=5403
ARK_COMPOSE_PROJECT=kurark-template
POSTGRES_DB=kurark_template
POSTGRES_USER=kurark_template
POSTGRES_PASSWORD=kurark_template
DATABASE_URL=postgres://kurark_template:kurark_template@localhost:5401/kurark_template
